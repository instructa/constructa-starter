# Client-side Base URL (optional - defaults to current origin in production)
VITE_BASE_URL="http://localhost:3000"

# Database URL
# -------------------------------------------------
DATABASE_URL="postgres://username:password@localhost:5432/dbname"

# Better Auth
# -------------------------------------------------
BETTER_AUTH_SECRET="your-secret-key-here"
SESSION_COOKIE_NAME=ex0_session
ENABLE_EMAIL_VERIFICATION=false

# E-MAIL Configuration
# -------------------------------------------------
## GENERAL
VITE_ENABLE_EMAIL_VERIFICATION="true"
EMAIL_FROM="noreply@example.com"

## Email Provider Configuration
EMAIL_PROVIDER="mailhog"  # Options: console, mailhog, smtp, resend

## RESEND
RESEND_API_KEY=""

# OAuth Providers (optional)
# -------------------------------------------------

## Github Login
VITE_GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

## Google Login
VITE_GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

TEST_BASE_URL="http://localhost:3000"

# Polar (for payments)
POLAR_ACCESS_TOKEN=
POLAR_SERVER="sandbox" # "sandbox" for testing, "production" for live
POLAR_WEBHOOK_SECRET=